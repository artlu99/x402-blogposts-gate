    "hono": "^4.12.15",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.13",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.4",
    "wrangler": "^4.86.0"
  }
